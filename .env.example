# Application
APP_ENV=development
APP_NAME=petalia-geospatial-engine
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-in-production-use-32-char-minimum
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=change-me-internal-api-key

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql+asyncpg://petalia:petalia_pass@localhost:5432/petalia_geo
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_LATEST=86400
REDIS_CACHE_TTL_TIMESERIES=604800
REDIS_CACHE_TTL_TILES=172800        # 48h — aligned with GEE tile URL expiration (S2-3)

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_CONCURRENCY=4

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/run/secrets/gee_service_account.json
GEE_PROJECT_ID=your-gcp-project-id

# Analysis Pipeline
ANALYSIS_CACHE_TTL_HOURS=48
NDVI_LOW_THRESHOLD=0.30
NDVI_DROP_THRESHOLD=0.20
CLOUD_COVER_THRESHOLD=0.30
# S2-2: New agronomic thresholds
NDMI_STRESS_THRESHOLD=-0.10          # NDMI < -0.10 → water stress alert
NDRE_LOW_THRESHOLD=0.20              # NDRE < 0.20 → nitrogen stress alert
VARIABILITY_HIGH_THRESHOLD=0.30     # VI > 0.30 → high variability alert
# Sentinel settings
SENTINEL_DATASET=COPERNICUS/S2_SR_HARMONIZED
SENTINEL_CLOUD_MAX=30
SENTINEL_DATE_RANGE_DAYS=30
# S3-1: Adaptive temporal window max (30 → 60 → 90 days)
SENTINEL_DATE_RANGE_MAX_DAYS=90
# S3-4: Max interactive field area (larger areas must use batch export)
MAX_FIELD_AREA_HA=50000
# S3-6: Composite method — median | p40 | p80 | quality_mosaic
COMPOSITE_METHOD=median
# S4-4: GEE batch export routing
MAX_INTERACTIVE_HA=5000             # Fields >= this use ee.batch.Export
GOOGLE_DRIVE_EXPORT_FOLDER=petalia_gee_exports  # GDrive folder name or ID

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ANALYSES=10/minute

# Monitoring
PROMETHEUS_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
SENTRY_DSN=
