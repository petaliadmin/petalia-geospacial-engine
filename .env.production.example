# Copy this to .env.production on the EC2 instance and fill real values
# NEVER commit .env.production to git
#
# NOTE: DATABASE_URL, REDIS_URL, CELERY_BROKER_URL, CELERY_RESULT_BACKEND
# are NOT listed here — docker-compose.prod.yml constructs and injects them
# automatically from POSTGRES_* and REDIS_PASSWORD below.

APP_ENV=production
APP_NAME=petalia-geospatial-engine
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-min-32-chars-random-string
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=change-me-internal-api-key

# Database (values must match docker-compose.prod.yml)
POSTGRES_DB=petalia_geo
POSTGRES_USER=petalia
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_PASSWORD=change-me-strong-password

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
GEE_PROJECT_ID=your-gcp-project-id
GEE_PRIVATE_KEY_PATH=/run/secrets/gee_service_account.json

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — your Flutter app domain / IP
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ANALYSES=10/minute

# Monitoring
PROMETHEUS_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
SENTRY_DSN=

# Flower UI credentials
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-strong-password

# Grafana
GRAFANA_PASSWORD=change-me-strong-password
